{
  "info": {
    "name": "Casas API - UPCH",
    "description": "CRUD de propiedades inmobiliarias - AWS Lambda + API Gateway",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://g3oak4ydna.execute-api.us-east-1.amazonaws.com/Prod",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Obtener todas las casas",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/casas?page=1&pageSize=20",
          "host": ["{{baseUrl}}"],
          "path": ["casas"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "pageSize", "value": "20" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Obtener casa por ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/casas/1",
          "host": ["{{baseUrl}}"],
          "path": ["casas", "1"]
        }
      },
      "response": []
    },
    {
      "name": "Crear casa",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"direccion\": \"Av. Universitaria 1234\",\n  \"distrito\": \"San Miguel\",\n  \"numeroHabitaciones\": 3,\n  \"tipoCasa\": \"Departamento\",\n  \"areaM2\": 85.5,\n  \"precio\": 150000,\n  \"descripcion\": \"Departamento moderno con buena iluminación\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/casas",
          "host": ["{{baseUrl}}"],
          "path": ["casas"]
        }
      },
      "response": []
    },
    {
      "name": "Actualizar casa",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"direccion\": \"Av. Universitaria 1234\",\n  \"distrito\": \"San Miguel\",\n  \"numeroHabitaciones\": 4,\n  \"tipoCasa\": \"Casa\",\n  \"areaM2\": 120.0,\n  \"precio\": 200000,\n  \"descripcion\": \"Casa amplia con jardín\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/casas/1",
          "host": ["{{baseUrl}}"],
          "path": ["casas", "1"]
        }
      },
      "response": []
    },
    {
      "name": "Eliminar casa",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/casas/1",
          "host": ["{{baseUrl}}"],
          "path": ["casas", "1"]
        }
      },
      "response": []
    }
  ]
}
